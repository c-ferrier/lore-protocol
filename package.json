{
  "name": "lore-protocol",
  "version": "0.4.0",
  "description": "CLI tool for the Lore protocol — structured decision context in git commits",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ian-stetsenko/lore-protocol"
  },
  "type": "module",
  "bin": {
    "lore": "./bin/lore.js"
  },
  "files": [
    "bin/",
    "dist/",
    "schemas/",
    "skills/"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "keywords": [
    "git",
    "cli",
    "lore",
    "decision-records",
    "ai-agents",
    "commit-messages",
    "institutional-knowledge"
  ],
  "author": "Ivan Stetsenko <dev.ivan.stetsenko@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "simple-update-notifier": "^2.0.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
